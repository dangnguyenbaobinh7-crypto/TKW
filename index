<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kiểm tra Mật khẩu</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background-color: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
        }
        h2 {
            text-align: center;
            color: #333;
        }
        input[type="password"] {
            width: 100%;
            padding: 10px;
            margin: 15px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 10px;
            background-color: #007BFF;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        button:hover {
            background-color: #0056b3;
        }
        .message {
            margin-top: 15px;
            line-height: 1.5;
            font-size: 14px;
        }
        .error {
            color: #d9534f;
        }
        .success {
            color: #5cb85c;
            font-weight: bold;
            font-size: 16px;
        }
        .strength {
            color: #333;
            font-weight: normal;
            font-size: 14px;
            margin-top: 5px;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Kiểm tra Mật khẩu</h2>
    <input type="password" id="passwordInput" placeholder="Nhập mật khẩu của bạn..." onkeydown="if(event.key === 'Enter') checkPassword()">
    <button onclick="checkPassword()">Kiểm tra</button>
    <div id="resultMessage" class="message"></div>
</div>

<script>
    function checkPassword() {
        const password = document.getElementById('passwordInput').value;
        const resultDiv = document.getElementById('resultMessage');
        
        
        resultDiv.innerHTML = '';
        resultDiv.className = 'message';

        
        let errors = [];

        
        if (password.length < 8) {
            errors.push("Ít nhất 8 ký tự.");
        }
        if (!/[A-Z]/.test(password)) {
            errors.push("Ít nhất một chữ cái viết hoa (A-Z).");
        }
        if (!/[a-z]/.test(password)) {
            errors.push("Ít nhất một chữ cái viết thường (a-z).");
        }
        if (!/[0-9]/.test(password)) {
            errors.push("Ít nhất một chữ số (0-9).");
        }
        
        if (!/[!@#$%^&*(),.?":{}|<>\-_=+\\[\]\\/';`~]/.test(password)) {
            errors.push("Ít nhất một ký tự đặc biệt (VD: @, #, $, %...).");
        }

        
        if (errors.length > 0) {
            resultDiv.classList.add('error');
            let errorHtml = "<strong>Mật khẩu không hợp lệ! Vui lòng nhập lại để đảm bảo:</strong><ul>";
            errors.forEach(error => {
                errorHtml += `<li>${error}</li>`;
            });
            errorHtml += "</ul>";
            resultDiv.innerHTML = errorHtml;
        } 
        
        else {
            let strength = "";
            let strengthColor = "";

            
            if (password.length === 8) {
                strength = "Yếu (Chỉ vừa đủ 8 ký tự)";
                strengthColor = "#f0ad4e"; 
            } else if (password.length > 8 && password.length < 12) {
                strength = "Trung bình";
                strengthColor = "#0275d8"; 
            } else if (password.length >= 12) {
                strength = "Mạnh";
                strengthColor = "#5cb85c"; /
            }

            resultDiv.classList.add('success');
            resultDiv.innerHTML = `
                Mật khẩu hợp lệ!
                <div class="strength">Độ mạnh: <span style="color: ${strengthColor}; font-weight: bold;">${strength}</span></div>
            `;
        }
    }
</script>

</body>
</html>
